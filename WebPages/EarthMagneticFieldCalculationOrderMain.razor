@page "/EarthMagneticField"
@inject ILogger<EarthMagneticFieldCalculationOrderMain> logger
@inject IEarthMagneticFieldAPIUtils Api
@inject ISnackbar Snackbar
@inject IDialogService DialogService
<MudUnitAndReferenceChoiceTag HttpHost=@Api.HostNameUnitConversion
                              HttpBasePath=@Api.HostBasePathUnitConversion
                              HttpController="UnitSystem/"
                              UnitSystemName="@DataUtils.UnitAndReferenceParameters.UnitSystemName"
                              UnitSystemNameChanged="@DataUtils.UpdateUnitSystemName">
    @if (earthMagneticFieldCalculationOrderList == null)
    {
        <p><em>Loading...</em></p>
    }
    else
    {
        <div hidden="@isHiddenMainPanel">
            <MudDataGrid T="EarthMagneticFieldCalculationOrder" MultiSelection="true" Items="@earthMagneticFieldCalculationOrderList" SelectedItemsChanged="@SelectedItemsChanged"
                         EditMode="DataGridEditMode.Cell"
                         Hover="true" 
                         SortMode="SortMode.Multiple" QuickFilter="@_earthMagneticFieldCalculationOrderFilter" Filterable="false"
                         ReadOnly="false" ColumnResizeMode="ResizeMode.Column" Elevation="0">
                <ToolBarContent>
                    <MudText Typo="Typo.h6">Earth Magnetic Field Calculator </MudText>
                    <MudButton OnClick="@AddEarthMagneticFieldCalculationOrder" Color="@Color.Success" Class="add-item-btn">Add</MudButton>
                    <MudButton OnClick="@DeleteSelectedEarthMagneticFieldCalculationOrder" Color="@Color.Error" Class="add-item-btn">Delete</MudButton>
                    <MudSpacer />
                    <MudTextField @bind-Value="_searchString" Placeholder="Search" Adornment="Adornment.Start" Immediate="true"
                                  AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
                </ToolBarContent>
                <Columns>
                    <SelectColumn T="EarthMagneticFieldCalculationOrder" />
                    <PropertyColumn Property="x => x.Name" Title="Earth Magnetic Fields" CellStyle="width: 30%;" Sortable="true" Editable="false" />
                    <PropertyColumn Property="x => x.Description" Title="Description" CellStyle="width: 40%;" Sortable="true" Editable="false" />
                    <TemplateColumn CellStyle="width: 25%;">
                        <EditTemplate>
                            <MudIconButton Size="@Size.Small" Icon="@Icons.Material.Outlined.Edit" OnClick="(() => EditEarthMagneticFieldCalculationOrder(context.Item.MetaInfo.ID))" />                                                
                            <MudIconButton Size="@Size.Small" Icon="@Icons.Material.Outlined.Delete" OnClick="(() => DeleteEarthMagneticFieldCalculationOrder(context.Item.MetaInfo.ID))" />
                        </EditTemplate>
                    </TemplateColumn>
                </Columns>
                <PagerContent>
                    <MudDataGridPager T="EarthMagneticFieldCalculationOrder" />
                </PagerContent>
            </MudDataGrid>

            <br/>
            <br/>

            <MudDataGrid T="EarthMagneticField" MultiSelection="true" Items="@earthMagneticFieldList" SelectedItemsChanged="@SelectedItemsChanged"
                         EditMode="DataGridEditMode.Cell"
                         Hover="true" 
                         SortMode="SortMode.Multiple" QuickFilter="@_earthMagneticFieldFilter" Filterable="false"
                         ReadOnly="false" ColumnResizeMode="ResizeMode.Column" Elevation="0">
                <ToolBarContent>
                    <MudText Typo="Typo.h6">Calculated Earth Magnetic Field</MudText>
                    <MudButton OnClick="@DeleteSelectedEarthMagneticField" Color="@Color.Error" Class="add-item-btn">Delete</MudButton>
                    <MudSpacer />
                    <MudTextField @bind-Value="_searchString" Placeholder="Search" Adornment="Adornment.Start" Immediate="true"
                                  AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium" Class="mt-0"></MudTextField>
                </ToolBarContent>
                <Columns>
                    <SelectColumn T="EarthMagneticField" />
                    <PropertyColumn Property="x => x.Name" Title="Calculation Orders" CellStyle="width: 30%;" Sortable="true" Editable="false" />
                    <PropertyColumn Property="x => x.Description" Title="Description" CellStyle="width: 40%;" Sortable="true" Editable="false" />
                    <TemplateColumn CellStyle="width: 25%;">
                        <EditTemplate>
                            <MudIconButton Size="@Size.Small" Icon="@Icons.Material.Outlined.Edit" OnClick="(() => ViewEarthMagneticField(context.Item.MetaInfo.ID))" />                                                
                            <MudIconButton Size="@Size.Small" Icon="@Icons.Material.Outlined.Delete" OnClick="(() => DeleteEarthMagneticField(context.Item.MetaInfo.ID))" />
                        </EditTemplate>
                    </TemplateColumn>
                </Columns>
                <PagerContent>
                    <MudDataGridPager T="EarthMagneticField" />
                </PagerContent>
            </MudDataGrid>
        </div>
    }
    @if (isHiddenMainPanel && (!isHiddenEditPanel))
    {
        <EarthMagneticFieldCalculationOrderEdit EarthMagneticFieldCalculationOrderId="@earthMagneticFieldCalculationOrderIdBeingEdited"  ValueChanged="HandleEditPanelClosed" />
    }
    @if (isHiddenMainPanel && (!isHiddenViewPanel))
    {
        <EarthMagneticFieldView EarthMagneticFieldId="@earthMagneticFieldIdBeingViewed"  ValueChanged="HandleEditPanelClosed" />
    }
</MudUnitAndReferenceChoiceTag>

@code{
    // EarthMagneticFieldCalculationOrder related variables
    private List<EarthMagneticFieldCalculationOrder> earthMagneticFieldCalculationOrderList = new();
    private List<EarthMagneticFieldCalculationOrder> selectedEarthMagneticFieldCalculationOrderList = new();
    private EarthMagneticFieldCalculationOrder? currentEarthMagneticFieldCalculationOrder;
    private List<object?>? inputDataList = new(); // container used to pass input data to the EarthMagneticFieldCalculationOrderEdit razor component without specifying content types (required by µservice Template)
                                                  // EarthMagneticField related variables
    private List<EarthMagneticField>? earthMagneticFieldList = new();
    private List<EarthMagneticField>? selectedEarthMagneticFieldList = new();

    // UI related variables
    public bool isHiddenMainPanel;
    public bool isHiddenEditPanel;
    private bool isHiddenViewPanel;
    private Guid? earthMagneticFieldCalculationOrderIdBeingEdited;
    private Guid? earthMagneticFieldIdBeingViewed;
    private string? _searchString;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // Show main panel
            isHiddenMainPanel = false;
            isHiddenEditPanel = true;
            currentEarthMagneticFieldCalculationOrder = null;

            // Starting all loading tasks asynchronously
            logger.LogInformation("Trying to load list of EarthMagneticField from client: " + Api.HttpClientEarthMagneticField);
            var earthMagneticFieldTask = Api.ClientEarthMagneticField.GetAllCompletedEarthMagneticFieldAsync(true);
            logger.LogInformation("Trying to load list of EarthMagneticFieldCalculationOrder from client: " + Api.HostNameEarthMagneticField);
            var earthMagneticFieldCalculationOrderTask = Api.ClientEarthMagneticField.GetAllEarthMagneticFieldCalculationOrderAsync();

            List<Task> loadingTaskList = new List<Task> { earthMagneticFieldCalculationOrderTask };
            loadingTaskList.Add(earthMagneticFieldTask);

            // Awaiting tasks and retrieve results as they become available
            while (loadingTaskList.Count > 0)
            {
                Task finishedTask = await Task.WhenAny(loadingTaskList);
                if (finishedTask == earthMagneticFieldCalculationOrderTask)
                {
                    try
                    {
                        earthMagneticFieldCalculationOrderList = (List<EarthMagneticFieldCalculationOrder>)await earthMagneticFieldCalculationOrderTask; // awaiting the finished task allows to retrieve its result and throw exception if needed
                        if (earthMagneticFieldCalculationOrderList != null)
                        {
                            earthMagneticFieldCalculationOrderList.Sort((t1, t2) => t1.Name.CompareTo(t2.Name));
                        }
                        else
                        {
                            logger.LogWarning("Returned list of EarthMagneticFieldCalculationOrder were null on initialization");
                            Snackbar.Add("Returned list of EarthMagneticFieldCalculationOrder were null on initialization", Severity.Warning);
                        }
                    }
                    catch (ApiException ex)
                    {
                        logger.LogError(ex, "Impossible to load EarthMagneticFieldCalculationOrder from client");
                    }
                }
                else if (finishedTask == earthMagneticFieldTask)
                {
                    try
                    {
                        earthMagneticFieldList = (List<EarthMagneticField>)await earthMagneticFieldTask; // awaiting the finished task allows to retrieve its result and throw exception if needed
                        if (earthMagneticFieldList != null)
                        {
                            earthMagneticFieldList.Sort((f1, f2) => f1.Name.CompareTo(f2.Name));
                        }
                        else
                        {
                            logger.LogWarning("Returned list of EarthMagneticField were null on initialization");
                            Snackbar.Add("Returned list of EarthMagneticField were null on initialization", Severity.Warning);
                        }
                    }
                    catch (ApiException ex)
                    {
                        logger.LogError(ex, "Impossible to load EarthMagneticField from client");
                    }
                }
                loadingTaskList.Remove(finishedTask);
            }
        }
        catch (Exception ex)
        {
            logger.LogError(ex, "Problem EarthMagneticFieldCalculationOrder initialization");
        }
        await InvokeAsync(() => { StateHasChanged(); });
    }

    private async Task AddEarthMagneticFieldCalculationOrder()
    {
        isHiddenMainPanel = true;
        isHiddenEditPanel = false;
        isHiddenViewPanel = true;
        earthMagneticFieldCalculationOrderIdBeingEdited = null;
    }

    private async Task EditEarthMagneticFieldCalculationOrder(Guid id)
    {
        isHiddenMainPanel = true;
        isHiddenEditPanel = false;
        isHiddenViewPanel = true;
        earthMagneticFieldCalculationOrderIdBeingEdited = id;
    }
    private async Task ViewEarthMagneticField(Guid id)
    {
        isHiddenMainPanel = true;
        isHiddenEditPanel = true;
        isHiddenViewPanel = false;
        earthMagneticFieldIdBeingViewed = id;
    }
    private async Task HandleEditPanelClosed()
    {
        isHiddenMainPanel = false;
        isHiddenEditPanel = true;
        isHiddenViewPanel = true;
        earthMagneticFieldCalculationOrderIdBeingEdited = null;
        await OnInitializedAsync();
    }

    private async Task<bool> ConfirmDeletion()
    {
        var options = new DialogOptions 
        { 
            CloseOnEscapeKey = true,
            MaxWidth = MaxWidth.Small,
            FullWidth = true    
        };
        var dialog = await DialogService.ShowAsync<DialogDeleteTemplate>("DELETE", options);
        var result = await dialog.Result;
        StateHasChanged();
        if (result == null)
        {
            return false;
        }
        else
        {
            return (!result.Canceled);
        }
    }
    private async Task DeleteEarthMagneticFieldCalculationOrder(Guid id)
    {
        try
        {
            if (await ConfirmDeletion())
            {
                await Api.ClientEarthMagneticField.DeleteEarthMagneticFieldCalculationOrderByIdAsync(id);
                await OnInitializedAsync();
            }
        }
        catch (Exception ex)
        {
            logger.LogError(ex, "Impossible to delete EarthMagneticFieldCalculationOrder");
        }
    }
    

    private async Task DeleteSelectedEarthMagneticFieldCalculationOrder()
    {
        try
        {
            if (await ConfirmDeletion())
            {
                foreach (EarthMagneticFieldCalculationOrder earthMagneticFieldCalculationOrder in selectedEarthMagneticFieldCalculationOrderList)
                {
                    await Api.ClientEarthMagneticField.DeleteEarthMagneticFieldCalculationOrderByIdAsync(earthMagneticFieldCalculationOrder.MetaInfo.ID);
                }
                await OnInitializedAsync();
            }
        }
        catch (Exception ex)
        {
            logger.LogError(ex, "Impossible to delete all EarthMagneticFieldCalculationOrder");
        }

    }
    private async Task DeleteSelectedEarthMagneticField()
    {
        try
        {
            if (await ConfirmDeletion())
            {
                foreach (EarthMagneticField earthMagneticField in selectedEarthMagneticFieldList!)
                {
                    await Api.ClientEarthMagneticField.DeleteEarthMagneticFieldCalculationOrderByIdAsync(earthMagneticField.MetaInfo.ID);
                }
                await OnInitializedAsync();
            }
        }
        catch (Exception ex)
        {
            logger.LogError(ex, "Impossible to delete all EarthMagneticFieldCalculationOrder");
        }
    }
    private async Task DeleteEarthMagneticField(Guid id)
    {
        try
        {
            if (await ConfirmDeletion())
            {
                await Api.ClientEarthMagneticField.DeleteEarthMagneticFieldByIdAsync(id);
                await OnInitializedAsync();
            }
        }
        catch (Exception ex)
        {
            logger.LogError(ex, "Impossible to delete EarthMagneticField");
        }
    }
    

    //Quick filter - filter gobally across multiple columns with the same input
    private Func<EarthMagneticFieldCalculationOrder, bool>
    _earthMagneticFieldCalculationOrderFilter => x =>
    {
        if (string.IsNullOrWhiteSpace(_searchString))
            return true;
        if ($"{x.Name} {x.Description}".Contains(_searchString))
            return true;

        return false;
    };
    private Func<EarthMagneticField, bool>
    _earthMagneticFieldFilter => x =>
    {
        if (string.IsNullOrWhiteSpace(_searchString))
            return true;
        if ($"{x.Name} {x.Description}".Contains(_searchString))
            return true;

        return false;
    };
    
    //Events
    private void StartedEditingItem(EarthMagneticFieldCalculationOrder item)
    {
        //Activating Edit event capture with parameter StartedEditingItem="@StartedEditingItem" in MudDataGrid; arguments are specified in OnClick="@context.Actions.StartedEditingItem(...)"
    }

    private void CancelledEditingItem(EarthMagneticFieldCalculationOrder item)
    {
        //Activating Cancel event capture with parameter CancelledEditingItem = "@CancelledEditingItem" in MudDataGrid; arguments are specified in OnClick="@context.Actions.CancelledEditingItem(...)"
    }

    private void CommittedItemChanges(EarthMagneticFieldCalculationOrder item)
    {
        //Activating Commit event capture with parameter CommittedItemChanges = "@CommittedItemChanges" in MudDataGrid; arguments are specified in OnClick="@context.Actions.CommittedEditingItem(...)"
    }

    void SelectedItemsChanged(HashSet<EarthMagneticFieldCalculationOrder>
        items)
    {
        selectedEarthMagneticFieldCalculationOrderList.Clear();
        selectedEarthMagneticFieldCalculationOrderList.InsertRange(0, items);
    }
     void SelectedItemsChanged(HashSet<EarthMagneticField>
        items)
    {
        selectedEarthMagneticFieldList.Clear();
        selectedEarthMagneticFieldList.InsertRange(0, items);
    }
}

